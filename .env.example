APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
BASE_URL=https://your-domain.com
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/swimdiary

ALLOW_FREE_EXPORTS=false
ALLOW_DEV_VIP=false

STRIPE_SECRET_KEY=sk_live_or_test_xxx
